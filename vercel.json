{
  "functions": {
    "api/recommend.py": {
      "maxDuration": 60
    },
    "api/books-recommend.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/filmtobooks",
      "destination": "/public/filmtobooks.html"
    },
    {
      "source": "/bookstofilms",
      "destination": "/public/bookstofilms.html"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}
